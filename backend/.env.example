# Environment variables for backend

# PostgreSQL connection
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Server port (optional, default 5000)
PORT=5000

# JWT secret for signing tokens (change this to a strong secret in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Frontend URL for CORS (optional, defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# --- Recurring Transaction Job ---
# Cron schedule for the recurring transaction processor (default: midnight daily)
# Format: minute hour day month weekday
# Examples:
#   '0 0 * * *'   = every day at midnight  (DEFAULT)
#   '*/5 * * * *' = every 5 minutes        (useful for local testing)
RECURRING_CRON_SCHEDULE=0 0 * * *

# Timezone for the cron job (default: Asia/Kolkata)
TZ=Asia/Kolkata
